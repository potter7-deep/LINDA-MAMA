{
  "name": "linda-mama-backend",
  "version": "1.0.0",
  "description": "Linda Mama Maternal Healthcare Management System Backend",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "postinstall": "echo 'Build skipped for dev setup'",
    "start": "node index.js",
    "dev": "node --watch index.js",
    "seed": "node seed/seedData.js",
"build": "cd ../frontend && npm ci && npm run build && cd ../backend && rsync -a ../frontend/dist/ ./public/ && npm ci && npm run seed",
    "deploy": "./deploy.sh",
    "pm2:dev": "pm2 start ecosystem.config.js",
    "pm2:prod": "pm2 start ecosystem.config.js --env production",
    "pm2:restart": "pm2 restart linda-mama-backend",
    "pm2:stop": "pm2 stop linda-mama-backend",
    "pm2:logs": "pm2 logs linda-mama-backend"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1"
  }
}
