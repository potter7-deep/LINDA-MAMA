# Linda Mama Backend - Render.com Environment Variables
# Copy to .env and customize

# Required
NODE_ENV=production
DB_PATH=/opt/render/project/src/linda_mama.db
JWT_SECRET=generate-64-char-super-secure-random-secret-here-lindamama-2024
JWT_EXPIRES_IN=24h

# Recommended
CORS_ORIGIN=https://linda-mama.onrender.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# Local dev (uncomment for local)
# NODE_ENV=development
# DB_PATH=./linda_mama.db
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

